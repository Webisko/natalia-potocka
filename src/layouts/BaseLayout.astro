---
import '../styles/global.css';
// Self-hosted fonts – RODO compliant, no data sent to Google
import '@fontsource/lato/latin-300.css';
import '@fontsource/lato/latin-400.css';
import '@fontsource/lato/latin-700.css';
import '@fontsource/playfair-display/latin-400.css';
import '@fontsource/playfair-display/latin-400-italic.css';
import '@fontsource/playfair-display/latin-600.css';
import '@fontsource/playfair-display/latin-600-italic.css';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { DEFAULT_SOCIAL_IMAGE, SITE_DESCRIPTION, SITE_NAME, SITE_URL } from '../../shared/siteConfig.js';
import { buildBreadcrumbSchema, buildPersonSchema, buildWebPageSchema, buildWebsiteSchema, toAbsoluteUrl } from '../lib/structuredData.js';
import { getGlobalSettings } from '../lib/globalSettings.js';

const globalSettings = getGlobalSettings();
const defaultTitle = globalSettings.seo_default_title || SITE_NAME;
const defaultDescription = globalSettings.seo_default_desc || SITE_DESCRIPTION;
const defaultSocialImage = globalSettings.seo_default_social_image || DEFAULT_SOCIAL_IMAGE;

interface Props {
  title: string;
  description?: string;
  socialImage?: string | null;
  canonicalUrl?: string | null;
  noindex?: boolean;
  ogType?: string;
  pageType?: string;
  breadcrumbItems?: Array<{ name: string; href?: string | null }>;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>> | null;
  showHeader?: boolean;
  showFooter?: boolean;
  showBreadcrumbs?: boolean;
}

const {
  title = defaultTitle,
  description = defaultDescription,
  socialImage = defaultSocialImage,
  canonicalUrl = null,
  noindex = false,
  ogType = 'website',
  pageType = 'WebPage',
  breadcrumbItems = [],
  structuredData = null,
  showHeader = true,
  showFooter = true,
  showBreadcrumbs = true,
} = Astro.props;

const siteUrl = Astro.site ? Astro.site.toString() : SITE_URL;
const resolvedCanonicalUrl = canonicalUrl
  ? new URL(canonicalUrl, siteUrl).toString()
  : toAbsoluteUrl(Astro.url.pathname || '/');
const resolvedSocialImage = socialImage
  ? new URL(socialImage, siteUrl).toString()
  : toAbsoluteUrl(DEFAULT_SOCIAL_IMAGE);
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const normalizedStructuredData = Array.isArray(structuredData)
  ? structuredData.filter(Boolean)
  : structuredData
    ? [structuredData]
    : [];
const defaultStructuredData = [
  buildPersonSchema(),
  buildWebsiteSchema(),
  buildWebPageSchema({
    title,
    description,
    path: Astro.url.pathname || '/',
    type: pageType,
    image: resolvedSocialImage,
  }),
  buildBreadcrumbSchema(breadcrumbItems),
].filter(Boolean);
const allStructuredData = [...defaultStructuredData, ...normalizedStructuredData];
const faviconHref = globalSettings.favicon_url || '/favicon.svg?v=np-monogram-1';
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="shortcut icon" href={faviconHref} />
    {resolvedCanonicalUrl && <link rel="canonical" href={resolvedCanonicalUrl} />}
    <meta property="og:locale" content="pl_PL" />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    {resolvedCanonicalUrl && <meta property="og:url" content={resolvedCanonicalUrl} />}
    {resolvedSocialImage && <meta property="og:image" content={resolvedSocialImage} />}
    <meta name="twitter:card" content={resolvedSocialImage ? 'summary_large_image' : 'summary'} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    {resolvedSocialImage && <meta name="twitter:image" content={resolvedSocialImage} />}
    {allStructuredData.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)}></script>
    ))}
  </head>
  <body class="min-h-screen flex flex-col bg-[#FAF7F2] relative">
    {showHeader && <SiteHeader />}
    <main class="flex-grow z-0">
      {showBreadcrumbs && <Breadcrumbs items={breadcrumbItems} />}
      <slot />
    </main>
    {showFooter && <SiteFooter />}
  </body>
 </html>
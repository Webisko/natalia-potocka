---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getGlobalSettings } from '../lib/globalSettings.js';

const globalSettings = getGlobalSettings();
const customMessage = globalSettings.maintenance_message || 'Trwają prace serwisowe. Wrócimy za chwilę.';
---

<BaseLayout
  title="Przerwa techniczna | Natalia Potocka"
  description="Strona jest chwilowo niedostępna z powodu prac serwisowych."
  noindex={true}
  showBreadcrumbs={false}
>
  <section class="relative flex min-h-[80vh] flex-col items-center justify-center overflow-hidden px-6 py-24">
    <div class="pointer-events-none absolute inset-0">
      <div class="absolute left-[-10%] top-[-5%] h-[60vw] w-[60vw] rounded-full bg-[#EADDD7]/40 blur-[130px]"></div>
      <div class="absolute right-[-5%] top-[20%] h-[40vw] w-[40vw] rounded-full bg-rose/10 blur-[110px]"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-xl text-center">
      <div class="mx-auto mb-8 flex h-20 w-20 items-center justify-center rounded-full border border-mauve/15 bg-white/60">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9 text-mauve/50" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z" />
        </svg>
      </div>

      <span class="section-eyebrow">Prace serwisowe</span>
      <h1 class="mt-6 font-serif text-4xl leading-tight text-mauve md:text-5xl">
        Wkrótce wracamy
      </h1>
      <p class="mx-auto mt-6 max-w-md text-lg leading-relaxed text-mauve/70">
        {customMessage}
      </p>

      <div class="mt-10">
        <a
          href="/"
          class="inline-flex h-14 items-center justify-center rounded-full border border-mauve/15 bg-white/60 px-8 text-sm font-bold uppercase tracking-widest text-mauve/70 transition-all hover:border-mauve/25 hover:text-mauve"
        >
          Spróbuj ponownie
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

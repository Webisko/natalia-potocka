---
import OptimizedImage from '../OptimizedImage.astro';
import { getProductKindLabel } from '../../lib/products.js';
import { getDigitalProductContent } from '../../lib/productContent.js';

const { product, shape = '46% 54% 39% 61% / 55% 38% 62% 45%' } = Astro.props;

const href = `/oferta/${product.slug}`;
const displayImage = product.thumbnail_url || getDigitalProductContent(product.slug)?.image || null;
const kindLabel = getProductKindLabel(product.type);
const iconVariant = product.type === 'audio' ? 'audio' : product.type === 'course' ? 'course' : 'video';
const iconBlobClass = iconVariant === 'audio'
  ? 'rounded-[58%_42%_36%_64%/44%_60%_40%_56%]'
  : iconVariant === 'course'
    ? 'rounded-[34%_66%_58%_42%/53%_37%_63%_47%]'
    : 'rounded-[42%_58%_65%_35%/38%_42%_58%_62%]';
const description = product.short_description || product.excerpt || getDigitalProductContent(product.slug)?.lead || product.description || '';
---

<article class="storefront-product-card group relative h-full">
  <div class="relative z-0 h-64 w-full md:h-72">
    <a href={href} class="absolute inset-0 z-10" aria-label={product.title}></a>
    <div class="absolute inset-0 overflow-hidden bg-white shadow-lg transition-all duration-700 ease-[cubic-bezier(0.65,0,0.076,1)] transform-gpu group-hover:!rounded-[26px] group-hover:shadow-xl" style={`border-radius: ${shape};`}>
      {displayImage ? (
        <OptimizedImage
          src={displayImage}
          alt={product.title}
          class="h-full w-full object-cover opacity-90 transition-transform duration-700 group-hover:scale-105 group-hover:opacity-100"
          loading="lazy"
          decoding="async"
          sizes="(min-width: 1280px) 18rem, (min-width: 1024px) 30vw, (min-width: 640px) 44vw, 86vw"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center bg-gradient-to-br from-blush/35 to-white px-6 text-center font-serif text-2xl text-mauve/25">{product.title}</div>
      )}
      <div class="absolute inset-0 bg-gradient-to-t from-mauve/45 via-mauve/10 to-transparent opacity-70"></div>
    </div>
  </div>

  <div class="relative z-10 mx-3 -mt-12 md:mx-4">
    <div class="h-full rounded-[26px] border border-mauve/5 bg-white p-5 shadow-[0_22px_60px_-36px_rgba(72,43,62,0.55)] transition-all duration-300 group-hover:-translate-y-2 group-hover:shadow-[0_28px_80px_-38px_rgba(72,43,62,0.58)] md:p-6">
      <div class="mb-3 flex items-start justify-between gap-4">
        <div class="min-w-0">
          <span class="mb-2 inline-flex w-fit items-center gap-1.5 rounded-full border border-mauve/10 bg-mauve/[0.04] px-2.5 py-1 text-[0.68rem] font-semibold uppercase tracking-[0.18em] text-mauve/60">
            <span class="h-1.5 w-1.5 rounded-full bg-gold/80"></span>
            {kindLabel}
          </span>
          <h3 class="font-serif text-[clamp(1.35rem,1.16rem+0.42vw,1.7rem)] leading-tight text-mauve transition-colors group-hover:text-terracotta">
            <a href={href}>{product.title}</a>
          </h3>
        </div>
        <div class:list={['flex h-10 w-10 flex-shrink-0 items-center justify-center bg-gold/10 text-gold transition-all duration-300 group-hover:scale-105 group-hover:bg-terracotta group-hover:text-white md:h-11 md:w-11', iconBlobClass]}>
          {iconVariant === 'audio' ? (
            <svg class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M3 18v-6a9 9 0 0118 0v6"></path>
              <path d="M21 19a2 2 0 01-2 2h-1a2 2 0 01-2-2v-3a2 2 0 012-2h3zM3 19a2 2 0 002 2h1a2 2 0 002-2v-3a2 2 0 00-2-2H3z"></path>
            </svg>
          ) : iconVariant === 'course' ? (
            <svg class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4 19.5A2.5 2.5 0 016.5 17H20"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.5 17A2.5 2.5 0 014 14.5v-9A2.5 2.5 0 016.5 3H20v14"></path>
            </svg>
          ) : (
            <svg class="h-4 w-4 md:h-5 md:w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <polygon points="23 7 16 12 23 17 23 7"></polygon>
              <rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect>
            </svg>
          )}
        </div>
      </div>

      <p class="line-clamp-3 text-[clamp(0.98rem,0.95rem+0.16vw,1.06rem)] font-light leading-relaxed text-mauve/82">
        {description}
      </p>
    </div>
  </div>
</article>
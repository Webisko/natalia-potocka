---
import BlobArrowIcon from './icons/BlobArrowIcon.astro';
import { getPagePathByKey } from '../lib/pageSettings.js';

const normalizePath = (value) => {
  if (!value) return '/';
  const normalized = value.endsWith('/') && value !== '/' ? value.slice(0, -1) : value;
  return normalized || '/';
};

const currentPath = normalizePath(Astro.url.pathname);
const aboutPath = normalizePath(getPagePathByKey('about'));
const contactPath = normalizePath(getPagePathByKey('contact'));
const offerPagePath = getPagePathByKey('offer');
const offerHref = offerPagePath === '/oferta' ? '/#oferta' : offerPagePath;
const isAbout = currentPath === aboutPath;
const isContact = currentPath === contactPath;
---

<>
  <header id="main-header" class="fixed left-0 right-0 top-0 z-50 bg-transparent py-4 transition-all duration-500 lg:py-5">
    <div class="mx-auto flex max-w-[1440px] items-center justify-between gap-4 px-5 sm:px-8 lg:px-12 xl:px-16">
      <div class="relative z-50">
        <a href="/" class="group flex flex-col">
          <span class="font-serif text-fs-title-lg font-bold leading-[0.9] tracking-tight text-mauve">
            Natalia Potocka
          </span>
          <span class="pt-1 text-fs-label font-medium uppercase tracking-[0.28em] text-gold transition-colors group-hover:text-mauve/70">
            Terapia &amp; Wsparcie
          </span>
        </a>
      </div>

      <div class="flex items-center gap-3 sm:gap-4">
        <nav class="hidden items-center gap-6 min-[1180px]:flex xl:gap-8">
        <a href={offerHref} class="group relative text-fs-ui font-medium uppercase tracking-wider text-mauve/80 transition-colors hover:text-terracotta">
          Oferta
          <span class="absolute -bottom-1 left-0 h-[1px] w-0 bg-terracotta transition-all duration-300 group-hover:w-full"></span>
        </a>
        <a href={aboutPath} class:list={[
          'group relative text-fs-ui font-medium uppercase tracking-wider transition-colors',
          isAbout ? 'text-terracotta' : 'text-mauve/80 hover:text-terracotta',
        ]}>
          O mnie
          <span class:list={[
            'absolute -bottom-1 left-0 h-[1px] bg-terracotta transition-all duration-300',
            isAbout ? 'w-full' : 'w-0 group-hover:w-full',
          ]}></span>
        </a>
        <a href="/#opinie" class="group relative text-fs-ui font-medium uppercase tracking-wider text-mauve/80 transition-colors hover:text-terracotta">
          Opinie
          <span class="absolute -bottom-1 left-0 h-[1px] w-0 bg-terracotta transition-all duration-300 group-hover:w-full"></span>
        </a>

        <div class="ml-2 flex items-center gap-4 xl:ml-4">
          <a href={contactPath}>
            <span class:list={[
              'group relative inline-flex h-[50px] min-w-[12rem] w-auto cursor-pointer items-center justify-start border-0 outline-none',
              isContact && 'opacity-100',
            ]}>
              <span class="circle absolute left-0 top-0 z-0 block h-[50px] w-[50px] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] bg-gold transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:w-full group-hover:rounded-[1.7rem]" aria-hidden="true">
                <BlobArrowIcon />
              </span>
              <span class="relative z-10 w-full whitespace-nowrap pl-14 pr-6 text-center text-fs-ui font-bold uppercase tracking-widest text-mauve transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:text-white">
                Skontaktuj się ze mną
              </span>
            </span>
          </a>

          <div id="header-auth-desktop" class="flex items-center gap-4">
            <button id="login-open-button" class="flex h-10 w-10 items-center justify-center border border-mauve/10 transition-all duration-500 group hover:border-terracotta hover:bg-terracotta/10" style="border-radius: 42% 58% 63% 37% / 38% 54% 46% 62%;" title="Zaloguj" type="button">
              <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-mauve transition-colors group-hover:text-terracotta">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
              </svg>
            </button>
          </div>
        </div>
        </nav>

        <div id="header-auth-mobile" class="flex items-center min-[1180px]:hidden">
          <button id="login-open-button-mobile" class="flex h-10 w-10 items-center justify-center border border-mauve/10 bg-white/70 transition-all duration-500 group hover:border-terracotta hover:bg-terracotta/10" style="border-radius: 42% 58% 63% 37% / 38% 54% 46% 62%;" title="Zaloguj" type="button">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-mauve transition-colors group-hover:text-terracotta">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
            </svg>
          </button>
        </div>

        <button
          id="mobile-menu-toggle"
          class="relative z-50 inline-flex h-11 w-11 items-center justify-center border border-mauve/10 bg-white/80 text-mauve transition-all duration-300 hover:border-terracotta hover:text-terracotta min-[1180px]:hidden"
          style="border-radius: 38% 62% 56% 44% / 41% 37% 63% 59%;"
          type="button"
          aria-expanded="false"
          aria-controls="mobile-menu-panel"
          aria-label="Otwórz menu"
        >
          <span class="sr-only">Otwórz menu</span>
          <span class="pointer-events-none relative block h-4 w-5">
            <span data-menu-line="top" class="absolute left-0 top-0 block h-[2px] w-5 rounded-full bg-current transition-all duration-300"></span>
            <span data-menu-line="middle" class="absolute left-0 top-[7px] block h-[2px] w-5 rounded-full bg-current transition-all duration-300"></span>
            <span data-menu-line="bottom" class="absolute left-0 top-[14px] block h-[2px] w-5 rounded-full bg-current transition-all duration-300"></span>
          </span>
        </button>
      </div>
    </div>
  </header>

  <div id="mobile-menu-backdrop" class="pointer-events-none fixed inset-0 z-40 bg-mauve/15 opacity-0 backdrop-blur-sm transition-opacity duration-300 min-[1180px]:hidden" aria-hidden="true"></div>

  <div id="mobile-menu-panel" class="pointer-events-none fixed inset-x-4 top-[5rem] z-40 translate-y-[-0.75rem] opacity-0 transition-all duration-300 min-[1180px]:hidden sm:inset-x-6 sm:top-[5.35rem]">
    <div class="overflow-hidden rounded-[2rem] border border-white/60 bg-white/95 p-6 shadow-[0_24px_80px_-40px_rgba(93,64,88,0.55)] backdrop-blur-xl sm:p-7">
      <nav class="flex flex-col gap-2">
        <a href={offerHref} class="rounded-2xl px-4 py-3 text-fs-ui font-semibold uppercase tracking-[0.18em] text-mauve transition-colors hover:bg-nude hover:text-terracotta">
          Oferta
        </a>
        <a href={aboutPath} class:list={[
          'rounded-2xl px-4 py-3 text-fs-ui font-semibold uppercase tracking-[0.18em] transition-colors hover:bg-nude hover:text-terracotta',
          isAbout ? 'bg-nude text-terracotta' : 'text-mauve',
        ]}>
          O mnie
        </a>
        <a href="/#opinie" class="rounded-2xl px-4 py-3 text-fs-ui font-semibold uppercase tracking-[0.18em] text-mauve transition-colors hover:bg-nude hover:text-terracotta">
          Opinie
        </a>
        <a href={contactPath} class:list={[
          'mt-2 inline-flex items-center justify-center rounded-[1.6rem] bg-gold px-5 py-4 text-center text-fs-label font-bold uppercase tracking-[0.18em] text-white transition-all hover:-translate-y-0.5 hover:bg-terracotta',
          isContact && 'bg-terracotta',
        ]}>
          Skontaktuj się ze mną
        </a>
      </nav>
    </div>
  </div>

  <div id="login-modal" class="fixed inset-0 z-[9999] hidden items-center justify-center">
    <div id="login-backdrop" class="absolute inset-0 bg-mauve/30 backdrop-blur-sm"></div>
    <div class="relative z-10 mx-4 w-full max-w-md bg-white/95 p-10 shadow-2xl backdrop-blur-xl" style="border-radius: 30px 30px 30px 30px;">
      <div class="pointer-events-none absolute right-0 top-0 h-40 w-40 translate-x-1/3 -translate-y-1/3 rounded-full bg-rose/10 blur-[50px]"></div>
      <div class="pointer-events-none absolute bottom-0 left-0 h-32 w-32 -translate-x-1/3 translate-y-1/3 rounded-full bg-gold/5 blur-[40px]"></div>

      <button id="login-close-button" class="absolute right-6 top-6 flex h-8 w-8 items-center justify-center text-mauve/50 transition-colors hover:text-mauve" type="button" aria-label="Zamknij">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"></path>
        </svg>
      </button>

      <div class="relative z-10">
        <h2 class="mb-2 font-serif text-fs-title-md text-mauve">Zaloguj się</h2>
        <p class="mb-8 text-fs-ui font-light text-mauve/50">Witaj ponownie. Wpisz dane swojego konta.</p>

        <div id="login-error" class="mb-4 hidden rounded-xl border border-rose/40 bg-rose/20 p-3 text-fs-ui font-semibold text-mauve shadow-sm"></div>

        <form id="login-form" class="flex flex-col gap-5">
          <div>
            <label class="mb-2 block text-fs-label font-bold uppercase tracking-wider text-mauve/70">Adres e-mail</label>
            <input id="login-email" type="email" class="w-full rounded-xl border border-mauve/10 bg-nude/80 px-5 py-3 font-light text-mauve transition-all focus:border-gold/30 focus:outline-none focus:ring-2 focus:ring-gold/30" placeholder="twoj@email.pl" required />
          </div>
          <div>
            <label class="mb-2 block text-fs-label font-bold uppercase tracking-wider text-mauve/70">Hasło</label>
            <input id="login-password" type="password" class="w-full rounded-xl border border-mauve/10 bg-nude/80 px-5 py-3 font-light text-mauve transition-all focus:border-gold/30 focus:outline-none focus:ring-2 focus:ring-gold/30" placeholder="••••••••" required />
          </div>

          <div class="flex flex-col gap-1">
            <button id="login-submit" type="submit" class="mt-2 h-14 overflow-hidden rounded-2xl bg-gold text-fs-label font-bold uppercase tracking-widest text-white transition-all duration-300 hover:-translate-y-0.5 hover:shadow-xl hover:shadow-gold/20 disabled:opacity-50">
              Zaloguj się
            </button>
            <div class="mt-3 text-center">
              <a href="/zapomnialam-hasla" class="text-fs-label text-mauve/50 transition-colors hover:text-gold">Zapomniałaś hasła?</a>
            </div>
          </div>
        </form>
      </div>
    </div>
  </div>

  <script>
    const header = document.getElementById('main-header');
    const desktopAuthContainer = document.getElementById('header-auth-desktop');
    const mobileAuthContainer = document.getElementById('header-auth-mobile');
    const loginOpenButton = document.getElementById('login-open-button');
    const mobileLoginOpenButton = document.getElementById('login-open-button-mobile');
    const loginModal = document.getElementById('login-modal');
    const loginBackdrop = document.getElementById('login-backdrop');
    const loginCloseButton = document.getElementById('login-close-button');
    const loginForm = document.getElementById('login-form');
    const loginError = document.getElementById('login-error');
    const loginSubmit = document.getElementById('login-submit');
    const loginEmail = document.getElementById('login-email');
    const loginPassword = document.getElementById('login-password');
    const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
    const mobileMenuPanel = document.getElementById('mobile-menu-panel');
    const mobileMenuBackdrop = document.getElementById('mobile-menu-backdrop');
    const mobileMenuLinks = mobileMenuPanel?.querySelectorAll('a') ?? [];

    let isMobileMenuOpen = false;

    const syncHeader = () => {
      if (!header) return;
      const isScrolled = window.scrollY > 20;
      header.classList.toggle('bg-transparent', !isScrolled);
      header.classList.toggle('py-4', !isScrolled);
      header.classList.toggle('bg-white/95', isScrolled);
      header.classList.toggle('backdrop-blur-md', isScrolled);
      header.classList.toggle('shadow-sm', isScrolled);
      header.classList.toggle('py-3', isScrolled);
    };

    const syncMobileMenuState = () => {
      if (!mobileMenuToggle || !mobileMenuPanel || !mobileMenuBackdrop) return;

      mobileMenuToggle.setAttribute('aria-expanded', String(isMobileMenuOpen));
      mobileMenuToggle.setAttribute('aria-label', isMobileMenuOpen ? 'Zamknij menu' : 'Otwórz menu');
      mobileMenuPanel.classList.toggle('pointer-events-none', !isMobileMenuOpen);
      mobileMenuPanel.classList.toggle('translate-y-[-0.75rem]', !isMobileMenuOpen);
      mobileMenuPanel.classList.toggle('opacity-0', !isMobileMenuOpen);
      mobileMenuPanel.classList.toggle('translate-y-0', isMobileMenuOpen);
      mobileMenuPanel.classList.toggle('opacity-100', isMobileMenuOpen);
      mobileMenuBackdrop.classList.toggle('pointer-events-none', !isMobileMenuOpen);
      mobileMenuBackdrop.classList.toggle('opacity-0', !isMobileMenuOpen);
      mobileMenuBackdrop.classList.toggle('opacity-100', isMobileMenuOpen);
      document.body.classList.toggle('overflow-hidden', isMobileMenuOpen);

      const topLine = mobileMenuToggle.querySelector('[data-menu-line="top"]');
      const middleLine = mobileMenuToggle.querySelector('[data-menu-line="middle"]');
      const bottomLine = mobileMenuToggle.querySelector('[data-menu-line="bottom"]');

      topLine?.classList.toggle('translate-y-[7px]', isMobileMenuOpen);
      topLine?.classList.toggle('rotate-45', isMobileMenuOpen);
      middleLine?.classList.toggle('opacity-0', isMobileMenuOpen);
      bottomLine?.classList.toggle('-translate-y-[7px]', isMobileMenuOpen);
      bottomLine?.classList.toggle('-rotate-45', isMobileMenuOpen);
    };

    const closeMobileMenu = () => {
      if (!isMobileMenuOpen) return;
      isMobileMenuOpen = false;
      syncMobileMenuState();
    };

    const toggleMobileMenu = () => {
      isMobileMenuOpen = !isMobileMenuOpen;
      syncMobileMenuState();
    };

    const openLoginModal = () => {
      if (!loginModal) return;
      loginModal.classList.remove('hidden');
      loginModal.classList.add('flex');
    };

    const closeLoginModal = () => {
      if (!loginModal) return;
      loginModal.classList.add('hidden');
      loginModal.classList.remove('flex');
      if (loginError) {
        loginError.textContent = '';
        loginError.classList.add('hidden');
      }
    };

    const loggedOutDesktopMarkup = `
        <button id="login-open-button" class="flex h-10 w-10 items-center justify-center border border-mauve/10 transition-all duration-500 group hover:border-terracotta hover:bg-terracotta/10" style="border-radius: 42% 58% 63% 37% / 38% 54% 46% 62%;" title="Zaloguj" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-mauve transition-colors group-hover:text-terracotta">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
          </svg>
        </button>
      `;

    const loggedOutMobileMarkup = `
        <button id="login-open-button-mobile" class="flex h-10 w-10 items-center justify-center border border-mauve/10 bg-white/70 transition-all duration-500 group hover:border-terracotta hover:bg-terracotta/10" style="border-radius: 42% 58% 63% 37% / 38% 54% 46% 62%;" title="Zaloguj" type="button">
          <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-mauve transition-colors group-hover:text-terracotta">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
          </svg>
        </button>
      `;

    const bindLoginOpenButtons = () => {
      document.getElementById('login-open-button')?.addEventListener('click', openLoginModal);
      document.getElementById('login-open-button-mobile')?.addEventListener('click', openLoginModal);
    };

    const renderLoggedOut = () => {
      if (desktopAuthContainer) {
        desktopAuthContainer.innerHTML = loggedOutDesktopMarkup;
      }
      if (mobileAuthContainer) {
        mobileAuthContainer.innerHTML = loggedOutMobileMarkup;
      }
      bindLoginOpenButtons();
    };

    const renderLoggedIn = (user) => {
      const panelHref = user?.is_admin ? '/administrator' : '/panel';
      if (desktopAuthContainer) {
        desktopAuthContainer.innerHTML = `
        <div class="flex items-center gap-4">
          <a href="${panelHref}" class="group flex h-10 w-10 items-center justify-center border border-mauve/10 transition-all duration-500 hover:border-terracotta hover:bg-terracotta/10" style="border-radius: 42% 58% 63% 37% / 38% 54% 46% 62%;" title="Moje konto">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-mauve transition-colors group-hover:text-terracotta">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
            </svg>
          </a>
          <button id="logout-button" class="flex items-center gap-2 text-fs-ui font-medium text-red-600 hover:opacity-80" type="button" title="Wyloguj">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-4 w-4">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0013.5 3h-7.5a2.25 2.25 0 00-2.25 2.25v13.5A2.25 2.25 0 006 21h7.5a2.25 2.25 0 002.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"></path>
            </svg>
          </button>
        </div>
      `;
      }

      if (mobileAuthContainer) {
        mobileAuthContainer.innerHTML = `
          <a href="${panelHref}" class="group flex h-10 w-10 items-center justify-center border border-mauve/10 bg-white/70 transition-all duration-500 hover:border-terracotta hover:bg-terracotta/10" style="border-radius: 42% 58% 63% 37% / 38% 54% 46% 62%;" title="Moje konto">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="h-5 w-5 text-mauve transition-colors group-hover:text-terracotta">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0A17.933 17.933 0 0112 21.75c-2.676 0-5.216-.584-7.499-1.632z"></path>
            </svg>
          </a>
        `;
      }

      desktopAuthContainer?.querySelector('#logout-button')?.addEventListener('click', async () => {
        await fetch('/api/auth/logout', { method: 'POST', credentials: 'include' });
        renderLoggedOut();
      });
    };

    const loadAuthState = async () => {
      try {
        const response = await fetch('/api/auth/me?optional=1&_t=' + Date.now(), { credentials: 'include' });
        if (!response.ok) {
          renderLoggedOut();
          return;
        }
        const session = await response.json().catch(() => null);
        if (!session?.authenticated || !session.user) {
          renderLoggedOut();
          return;
        }
        renderLoggedIn(session.user);
      } catch {
        renderLoggedOut();
      }
    };

    const handleViewportChange = () => {
      if (window.innerWidth >= 1180) {
        closeMobileMenu();
      }
    };

    window.addEventListener('scroll', syncHeader, { passive: true });
    window.addEventListener('resize', handleViewportChange, { passive: true });
    syncHeader();
    loginBackdrop?.addEventListener('click', closeLoginModal);
    loginCloseButton?.addEventListener('click', closeLoginModal);
    mobileMenuToggle?.addEventListener('click', toggleMobileMenu);
    mobileMenuBackdrop?.addEventListener('click', closeMobileMenu);
    mobileMenuLinks.forEach((link) => link.addEventListener('click', closeMobileMenu));
    bindLoginOpenButtons();
    syncMobileMenuState();

    loginForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (!(loginSubmit instanceof HTMLButtonElement) || !(loginEmail instanceof HTMLInputElement) || !(loginPassword instanceof HTMLInputElement) || !loginError) return;
      loginSubmit.setAttribute('disabled', 'disabled');
      loginSubmit.textContent = 'Logowanie...';
      loginError.textContent = '';
      loginError.classList.add('hidden');

      try {
        const response = await fetch('/api/auth/login', {
          method: 'POST',
          credentials: 'include',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            email: loginEmail.value,
            password: loginPassword.value,
          }),
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || 'Nie udało się zalogować. Sprawdź adres e-mail i hasło.');
        }

        closeLoginModal();
        renderLoggedIn(payload.user || null);
        const destination = payload?.user?.is_admin ? '/administrator' : '/panel';
        window.location.href = destination;
      } catch (error) {
        loginError.textContent = error instanceof Error ? error.message : 'Nie udało się zalogować. Sprawdź adres e-mail i hasło.';
        loginError.classList.remove('hidden');
      } finally {
        loginSubmit.removeAttribute('disabled');
        loginSubmit.textContent = 'Zaloguj się';
      }
    });

    loadAuthState();
  </script>
</>
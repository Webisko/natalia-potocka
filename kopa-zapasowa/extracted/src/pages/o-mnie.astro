---
import BaseLayout from '../layouts/BaseLayout.astro';
import AboutPageContent from '../components/pages/AboutPageContent.astro';
import { PAGE_SETTINGS_BY_KEY } from '../../shared/pageDefaults.js';
import { getPagePathByKey, getPageSettings, normalizePagePath } from '../lib/pageSettings.js';

const page = getPageSettings('about');
const currentPath = normalizePagePath(Astro.url.pathname);
const configuredPath = normalizePagePath(getPagePathByKey('about'));
const breadcrumbItems = [
  { name: 'Strona główna', href: '/' },
  { name: page?.title || PAGE_SETTINGS_BY_KEY.about.title, href: configuredPath },
];

if (configuredPath !== currentPath) {
  return Astro.redirect(configuredPath);
}
---

<BaseLayout
  title={page?.meta_title || page?.title || PAGE_SETTINGS_BY_KEY.about.meta_title}
  description={page?.meta_desc || PAGE_SETTINGS_BY_KEY.about.meta_desc}
  socialImage={page?.meta_image_url || page?.featured_image_url || null}
  canonicalUrl={page?.canonical_url || null}
  noindex={Boolean(page?.noindex)}
  pageType="AboutPage"
  showBreadcrumbs={false}
  breadcrumbItems={breadcrumbItems}
>
  <AboutPageContent
    featuredImageSrc={page?.featured_image_url || PAGE_SETTINGS_BY_KEY.about.featured_image_url}
    offerPagePath={getPagePathByKey('offer')}
  />
</BaseLayout>
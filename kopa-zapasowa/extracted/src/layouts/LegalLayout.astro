---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  lead: string;
  seoTitle?: string;
  seoDescription?: string;
  socialImage?: string | null;
  canonicalUrl?: string | null;
  noindex?: boolean;
  pageType?: string;
  breadcrumbItems?: Array<{ name: string; href?: string | null }>;
  structuredData?: Record<string, unknown> | Array<Record<string, unknown>> | null;
}

const {
  title,
  lead,
  seoTitle = `${title} | Natalia Potocka`,
  seoDescription = lead,
  socialImage = null,
  canonicalUrl = null,
  noindex = false,
  pageType = 'WebPage',
  breadcrumbItems = [],
  structuredData = null,
} = Astro.props;
---

<BaseLayout title={seoTitle} description={seoDescription} socialImage={socialImage} canonicalUrl={canonicalUrl} noindex={noindex} pageType={pageType} breadcrumbItems={breadcrumbItems} structuredData={structuredData}>
  <section class="relative overflow-hidden px-6 py-16 md:px-12 md:py-24">
    <div class="absolute inset-0 bg-gradient-to-br from-blush/30 via-nude to-white"></div>
    <div class="absolute left-[8%] top-10 h-72 w-72 rounded-full bg-rose/15 blur-[90px]"></div>
    <div class="absolute bottom-0 right-[5%] h-80 w-80 rounded-full bg-gold/10 blur-[100px]"></div>

    <div class="container-shell relative z-10 max-w-4xl text-center">
      <span class="section-eyebrow">Informacje prawne</span>
      <h1 class="mt-6 font-serif text-fs-title-xl leading-tight text-mauve">{title}</h1>
      <p class="mx-auto mt-6 max-w-2xl text-fs-body-lg leading-relaxed text-mauve/70">{lead}</p>
    </div>
  </section>

  <section class="px-6 pb-20 md:px-12">
    <div class="container-shell max-w-4xl card-surface p-8 md:p-12">
      <div class="legal-copy">
        <slot />
      </div>
    </div>
  </section>
</BaseLayout>
---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Panel klientki Natalii Potockiej.',
  noindex = true,
} = Astro.props;

const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const faviconHref = '/favicon.svg?v=np-monogram-1';
---

<!doctype html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <link rel="icon" type="image/svg+xml" href={faviconHref} />
    <link rel="shortcut icon" href={faviconHref} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Lato:ital,wght@0,300;0,400;0,700;1,300;1,400&family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500;1,600&display=swap" />
  </head>
  <body class="min-h-screen bg-nude text-mauve antialiased">
    <slot />
  </body>
</html>
---
import ProductCheckout from '../ProductCheckout.astro';
import { getCourseByProductId } from '../../lib/courses.js';
import RichTextContent from '../RichTextContent.astro';
import { extractRichTextLead, extractRichTextListItems } from '../../../shared/richText.js';
import OptimizedImage from '../OptimizedImage.astro';

const { product } = Astro.props;
const course = getCourseByProductId(product.id);
const modules = course?.modules || [];
const totalLessons = modules.reduce((sum, module) => sum + (module.lessons?.length || 0), 0);
const learningPoints = extractRichTextListItems(product.description);
const leadText = extractRichTextLead(product.description) || 'Kompleksowy program, który poprowadzi Cię krok po kroku.';
const secondaryImage = product.secondary_image_url || null;
---

<div class="w-full bg-surface">
  <section class="relative flex min-h-[60vh] items-center overflow-hidden pb-16">
    <div class="absolute inset-0 z-0">
      {product.thumbnail_url ? (
        <OptimizedImage src={product.thumbnail_url} alt={product.title} class="h-full w-full object-cover" loading="eager" decoding="async" fetchpriority="high" sizes="100vw" />
      ) : (
        <div class="h-full w-full bg-gradient-to-br from-mauve to-mauve/80"></div>
      )}
      <div class="absolute inset-0 bg-mauve/85 backdrop-blur-sm"></div>
    </div>

    <div class="container-shell relative z-10 w-full pt-8">
      <div class="max-w-3xl">
        <span class="text-fs-label inline-block rounded-full bg-gold/20 px-4 py-1.5 font-bold uppercase tracking-widest text-gold">Kurs Online</span>
        <h1 class="mt-6 font-serif text-4xl leading-tight text-white md:text-6xl">{product.title}</h1>
        <p class="mt-8 max-w-2xl text-[1.35rem] font-light leading-relaxed text-white/78">{leadText}</p>
        <div class="mt-10 flex flex-wrap gap-8 text-sm font-medium tracking-wide text-white/60">
          <div class="flex items-center gap-2"><span class="text-gold">✦</span>{modules.length} modułów</div>
          <div class="flex items-center gap-2"><span class="text-gold">▶</span>{totalLessons} lekcji</div>
          <div class="flex items-center gap-2"><span class="text-gold">∞</span>Dostęp dożywotni</div>
        </div>
      </div>
    </div>

    <div class="absolute bottom-0 left-0 right-0 h-20 bg-surface" style="clip-path: polygon(0 100%, 100% 100%, 100% 30%, 0 100%);"></div>
  </section>

  {secondaryImage && (
    <section class="container-shell pb-8 pt-2 md:pb-12">
      <div class="overflow-hidden rounded-[34px] border border-white/80 bg-white/80 p-3 shadow-soft backdrop-blur-sm">
        <OptimizedImage
          src={secondaryImage}
          alt={`${product.title} - dodatkowy obrazek`}
          class="h-full max-h-[720px] w-full rounded-[28px] object-cover"
          loading="lazy"
          decoding="async"
          sizes="(min-width: 1024px) 1200px, 100vw"
        />
      </div>
    </section>
  )}

  <section class="container-shell relative pb-24 pt-8">
    <div class="flex flex-col gap-12 lg:flex-row">
      <div class="flex-1">
        {product.description ? (
          <div class="mb-16 rounded-[28px] border border-white/80 bg-white/60 p-6 md:p-8">
            <h2 class="text-2xl font-serif text-mauve md:text-3xl">Opis kursu</h2>
            <div class="mt-6">
              <RichTextContent value={product.description} />
            </div>
          </div>
        ) : null}

        <div class="mb-16">
          <h2 class="mb-8 font-serif text-2xl text-mauve md:text-3xl">Czego się nauczysz</h2>
          {learningPoints.length > 0 && (
            <div class="space-y-3">
              {learningPoints.map((point) => (
                <div class="flex items-start gap-3">
                  <div class="text-fs-label mt-0.5 flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-gold/10 text-gold">✓</div>
                  <p class="text-lg leading-8 text-mauve/70">{point}</p>
                </div>
              ))}
            </div>
          )}
          {learningPoints.length === 0 && !product.description && <p class="font-light text-mauve/60">Opis programu pojawi się tutaj wkrótce.</p>}
        </div>

        {modules.length > 0 && (
          <div class="mb-16">
            <h2 class="mb-8 font-serif text-2xl text-mauve md:text-3xl">Program kursu</h2>
            <div class="space-y-3">
              {modules.map((module) => (
                <details class="overflow-hidden rounded-2xl border border-mauve/10 bg-white/60">
                  <summary class="flex cursor-pointer list-none items-center justify-between p-5 text-left hover:bg-white/80">
                    <div class="flex items-center gap-4">
                      <div class="flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full bg-mauve/5 text-mauve/40">✦</div>
                      <div>
                        <h3 class="font-serif text-mauve">{module.title}</h3>
                        <span class="text-fs-label font-light text-mauve/40">{module.lessons?.length || 0} lekcji</span>
                      </div>
                    </div>
                    <span class="text-mauve/40">⌄</span>
                  </summary>
                  <div class="divide-y divide-mauve/5">
                    {(module.lessons || []).map((lesson) => (
                      <div class="flex items-center gap-4 bg-white/30 px-5 py-3">
                        <span class="text-sm text-gold">{lesson.lesson_type === 'audio' ? '♪' : lesson.lesson_type === 'text' ? '≡' : '▶'}</span>
                        <span class="flex-1 text-base leading-7 text-mauve/70">{lesson.title}</span>
                        {lesson.duration_minutes && <span class="text-fs-label font-light text-mauve/30">{lesson.duration_minutes} min</span>}
                        <span class="flex-shrink-0 text-mauve/20">🔒</span>
                      </div>
                    ))}
                  </div>
                </details>
              ))}
            </div>
            <p class="text-fs-ui mt-4 flex items-center gap-2 font-light text-mauve/40">
              <span>🔒</span> Pełny dostęp po zakupie kursu.
            </p>
          </div>
        )}
      </div>

      <div class="w-full flex-shrink-0 lg:w-80">
        <div class="sticky top-32 rounded-[30px] border border-gold/10 bg-nude p-8 shadow-sm">
          <h3 class="text-2xl font-serif text-mauve">Dołącz do kursu</h3>
          <p class="mt-2 text-base font-light leading-7 text-mauve/55">Natychmiastowy dostęp do wszystkich materiałów.</p>
          <div class="mb-6 mt-6">
            {product.promoActive ? (
              <>
                <div class="mb-1 font-serif text-xl text-mauve/30 line-through">{product.price.toFixed(2)} PLN</div>
                <span class="font-serif text-5xl font-light text-mauve">{product.currentPrice.toFixed(2)}</span>
                <span class="text-fs-ui ml-2 text-mauve/40">PLN</span>
              </>
            ) : (
              <>
                <span class="font-serif text-5xl font-light text-mauve">{product.price.toFixed(2)}</span>
                <span class="text-fs-ui ml-2 text-mauve/40">PLN</span>
              </>
            )}
          </div>

          {product.promoActive && product.lowest_price_30_days != null && (
            <div class="text-fs-label mb-6 -mt-3 border-l-2 border-gold/30 pl-3 font-light text-mauve/40">
              Najniższa cena z 30 dni przed obniżką: <span class="font-bold">{product.lowest_price_30_days.toFixed(2)} PLN</span>
            </div>
          )}

          <ProductCheckout
            product={product}
            layout="inline"
            buttonLabel="Kup Dostęp Teraz"
            buttonClass="text-fs-label flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-gold font-bold uppercase tracking-widest text-white transition-all hover:shadow-xl hover:shadow-gold/20"
            purchasedLabel="Rozpocznij Naukę"
            purchasedClass="flex h-14 w-full items-center justify-center gap-2 rounded-xl bg-mauve font-medium tracking-wide text-white shadow-lg transition-all hover:bg-mauve/90"
            showSupportLink={false}
            showNote={false}
          />

          <ul class="mt-6 space-y-3 border-t border-mauve/10 pt-6">
            {['Materiały wideo Full HD', 'Ćwiczenia i karty pracy', 'Pliki do pobrania', 'Dostęp dożywotni'].map((feature) => (
              <li class="flex items-center gap-3 text-base font-light leading-7 text-mauve/60">
                <div class="text-fs-label flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full bg-gold/10 text-gold">✓</div>
                {feature}
              </li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>
</div>

---
import BlobArrowIcon from '../icons/BlobArrowIcon.astro';
import OptimizedImage from '../OptimizedImage.astro';

const featuredImageSrc = Astro.props.featuredImageSrc || '/images/about_doula.png';
const offerPagePath = Astro.props.offerPagePath || '/#oferta';
---

<div class="w-full bg-nude">
  <section class="relative flex min-h-[70vh] items-center overflow-hidden pb-20 pt-10">
    <div class="pointer-events-none absolute inset-0 -z-10"></div>
    <div class="pointer-events-none absolute bottom-0 left-0 z-20 h-32 w-full bg-gradient-to-t from-nude via-nude/80 to-transparent"></div>
    <svg class="absolute inset-0 h-full w-full pointer-events-none opacity-20" viewBox="0 0 1440 600" preserveAspectRatio="none">
      <path d="M-100,300 C300,100 700,500 1100,250 C1350,100 1500,300 1700,200" fill="none" stroke="#D4AF37" stroke-width="1.5" stroke-dasharray="8 18" class="animate-flow-vein-gold"></path>
      <path d="M-100,360 C300,160 700,560 1100,310 C1350,160 1500,360 1700,260" fill="none" stroke="#E6B8B8" stroke-width="2" stroke-dasharray="14 28" class="animate-flow-vein-rose"></path>
    </svg>
    <div class="absolute right-[10%] top-20 h-60 w-60 rounded-full bg-blush/25 blur-[80px] animate-breathe"></div>
    <div class="absolute bottom-10 left-[5%] h-64 w-64 rounded-full bg-rose/15 blur-[90px] animate-pulse-slow"></div>
    <div class="absolute right-[20%] top-1/2 h-28 w-28 rounded-full border border-gold/15 animate-pulse-slow"></div>

    <div class="relative z-10 mx-auto flex w-full max-w-[1440px] flex-col items-center gap-16 px-8 md:flex-row md:px-16">
      <div class="flex-1 text-center md:text-left">
        <div class="mb-8 inline-flex items-center gap-2">
          <svg class="h-4 w-4 animate-heartbeat text-terracotta" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
          </svg>
          <span class="text-fs-label font-bold uppercase tracking-[0.2em] text-terracotta">O mnie</span>
        </div>
        <h1 class="mb-8 font-serif text-4xl leading-[1.05] text-mauve md:text-6xl lg:text-7xl">Matematyczka,<br />która zaufała <span class="bg-gradient-to-r from-gold to-[#B88A44] bg-clip-text italic text-transparent">intuicji.</span></h1>
        <p class="mb-10 max-w-2xl text-lg font-light leading-relaxed text-mauve/70 md:text-xl">Jestem edukatorką okołoporodową i terapeutką traumy. Łączę analityczny umysł z głęboką empatią – by być przy Tobie w sposób, który naprawdę ma znaczenie.</p>
        <a href="/konsultacja-indywidualna" class="group relative inline-flex h-[50px] min-w-[12rem] w-auto cursor-pointer items-center justify-start border-0 outline-none">
          <span class="circle absolute left-0 top-0 z-0 block h-[50px] w-[50px] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] bg-gold transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:w-full group-hover:rounded-[1.7rem]" aria-hidden="true">
            <BlobArrowIcon />
          </span>
          <span class="relative z-10 w-full whitespace-nowrap pl-14 pr-6 text-center text-fs-ui font-bold uppercase tracking-widest text-mauve transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:text-white">Umów konsultację</span>
        </a>
      </div>

      <div class="flex shrink-0 justify-center">
        <div class="relative h-[380px] w-[300px] md:h-[480px] md:w-[380px]">
          <div class="absolute inset-0 scale-110 animate-morph bg-rose/20 blur-md" style="border-radius: 56% 44% 30% 70% / 60% 30% 70% 40%;"></div>
          <div class="absolute inset-0 scale-110 animate-morph border border-gold/30" style="animation-delay: 2s; border-radius: 56% 44% 30% 70% / 60% 30% 70% 40%;"></div>
          <div class="relative h-full w-full overflow-hidden shadow-2xl" style="border-radius: 56% 44% 30% 70% / 60% 30% 70% 40%;">
            <OptimizedImage src={featuredImageSrc} alt="Natalia Potocka" class="h-full w-full object-cover" loading="eager" decoding="async" fetchpriority="high" sizes="(min-width: 768px) 380px, 300px" />
          </div>
          <div class="absolute -bottom-6 -right-6 h-24 w-24 rounded-full bg-gold/10 blur-xl animate-heartbeat"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-8 py-28 md:px-16">
    <svg class="absolute right-0 top-0 h-full opacity-15 pointer-events-none" viewBox="0 0 300 800">
      <path d="M300,0 C100,200 200,400 50,600 C0,700 100,800 300,800" fill="none" stroke="#D4AF37" stroke-width="2" stroke-dasharray="6 12" class="animate-flow-vein-gold"></path>
    </svg>
    <div class="absolute left-[-5%] top-1/2 h-80 w-80 -translate-y-1/2 rounded-full bg-blush/20 blur-[80px] animate-breathe"></div>

    <div class="relative z-10 mx-auto max-w-[1440px]">
      <div class="flex flex-col items-center gap-20 lg:flex-row">
        <div class="flex justify-center lg:w-1/2">
          <div class="relative h-[420px] w-[320px] md:h-[540px] md:w-[420px]">
            <div class="absolute inset-0 scale-110 animate-morph bg-rose/20 blur-md" style="border-radius: 40% 60% 60% 40% / 55% 45% 55% 45%;"></div>
            <div class="absolute inset-0 scale-110 animate-morph border border-gold/30" style="animation-delay: 2s; border-radius: 40% 60% 60% 40% / 55% 45% 55% 45%;"></div>
            <div class="relative h-full w-full overflow-hidden shadow-xl" style="border-radius: 40% 60% 60% 40% / 55% 45% 55% 45%;">
              <OptimizedImage src={featuredImageSrc} alt="Natalia Potocka" class="h-full w-full object-cover" loading="lazy" decoding="async" sizes="(min-width: 768px) 420px, 320px" />
              <div class="absolute inset-0 bg-gradient-to-t from-mauve/20 to-transparent"></div>
            </div>
            <div class="absolute -bottom-6 -right-6 h-24 w-24 rounded-full bg-gold/10 blur-xl animate-heartbeat"></div>
          </div>
        </div>

        <div class="lg:w-1/2">
          <div class="mb-6 inline-flex items-center gap-2">
            <svg class="h-4 w-4 text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"></path>
              <path stroke-linecap="round" stroke-linejoin="round" d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"></path>
            </svg>
            <span class="text-fs-label font-bold uppercase tracking-[0.2em] text-gold">Moja historia</span>
          </div>
          <h2 class="mb-8 font-serif text-3xl leading-tight text-mauve md:text-4xl">Więcej niż wiedza –<br /><span class="italic text-gold">zaopiekowane emocje.</span></h2>
          <div class="space-y-5 text-lg font-light leading-relaxed text-mauve/70">
            <p>Jestem edukatorką okołoporodową, ale wiedza to nie wszystko. Wierzę, że w przygotowaniu do macierzyństwa kluczowe są zaopiekowane emocje.</p>
            <p>Łączę analityczny umysł (z wykształcenia jestem matematyczką!) z głęboką empatią i kompetencjami terapeutki traumy. Jestem tu, by wesprzeć Cię we wszystkim, co aktualnie przeżywasz – <span class="font-medium text-mauve">bez oceniania</span>.</p>
            <p>Macierzyństwo nie powinno być samotną podróżą przez gąszcz sprzecznych informacji. Moją rolą jest być przy Tobie – jako przewodniczka, edukatorka i po prostu ktoś, komu możesz zaufać.</p>
            <p>Pracuję w nurcie hipnoterapii (technika Rewind) oraz edukacji okołoporodowej opartej na dowodach naukowych. Każda kobieta jest inna – dlatego moje podejście jest zawsze dopasowane do Ciebie.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="relative overflow-hidden px-8 pb-20 pt-28 md:px-16">
    <div class="absolute right-[-5%] top-[10%] h-80 w-80 rounded-full bg-rose/12 blur-[80px] animate-breathe"></div>
    <div class="absolute bottom-[10%] left-[-5%] h-72 w-72 rounded-full bg-blush/15 blur-[60px] animate-pulse-slow"></div>
    <svg class="absolute left-[50%] top-0 h-full opacity-12 pointer-events-none" viewBox="0 0 200 800">
      <path d="M100,0 C50,200 150,400 80,600 C30,750 120,800 100,800" fill="none" stroke="#E6B8B8" stroke-width="2" stroke-dasharray="10 20" class="animate-flow-vein-rose"></path>
    </svg>

    <div class="relative z-10 mx-auto max-w-[1440px]">
      <div class="mx-auto mb-20 max-w-3xl text-center">
        <div class="mb-4 inline-flex items-center gap-2">
          <svg class="h-4 w-4 animate-heartbeat text-gold" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l2.03 6.233a1 1 0 00.95.69h6.555c.969 0 1.371 1.24.588 1.81l-5.302 3.852a1 1 0 00-.364 1.118l2.03 6.234c.3.92-.755 1.688-1.54 1.118l-5.302-3.853a1 1 0 00-1.176 0l-5.302 3.853c-.784.57-1.838-.197-1.539-1.118l2.03-6.234a1 1 0 00-.364-1.118L.98 11.66c-.783-.57-.38-1.81.588-1.81h6.555a1 1 0 00.95-.69l2.03-6.233z"></path>
          </svg>
          <span class="text-fs-label font-bold uppercase tracking-[0.2em] text-gold">Sprawdź ofertę</span>
        </div>
        <h2 class="mb-8 font-serif text-4xl leading-[1.1] text-mauve md:text-6xl">Każda kobieta zasługuje na <span class="bg-gradient-to-r from-terracotta to-gold bg-clip-text italic text-transparent">wsparcie, które czuje.</span></h2>
        <p class="mx-auto mb-12 max-w-2xl text-lg font-light leading-relaxed text-mauve/65 md:text-xl">Przejrzyj dostępne formy wsparcia – od terapii traumy i konsultacji indywidualnych, po nagrania webinarów i medytacje, które możesz odtwarzać kiedy chcesz.</p>
        <div class="flex flex-col items-center justify-center gap-5 sm:flex-row">
          <a href={offerPagePath} class="group relative inline-flex h-[50px] min-w-[12rem] w-auto cursor-pointer items-center justify-start border-0 outline-none">
            <span class="circle absolute left-0 top-0 z-0 block h-[50px] w-[50px] rounded-[40%_60%_70%_30%/40%_50%_60%_50%] bg-gold transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:w-full group-hover:rounded-[1.7rem]" aria-hidden="true">
              <BlobArrowIcon />
            </span>
            <span class="relative z-10 w-full whitespace-nowrap pl-14 pr-6 text-center text-fs-ui font-bold uppercase tracking-widest text-mauve transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:text-white">Terapia i konsultacje</span>
          </a>
          <a href={offerPagePath} class="group relative inline-flex h-[50px] min-w-[12rem] w-auto cursor-pointer items-center justify-start border-0 outline-none">
            <span class="circle absolute left-0 top-0 z-0 block h-[50px] w-[50px] rounded-[60%_40%_30%_70%/60%_30%_70%_40%] bg-mauve transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:w-full group-hover:rounded-[1.7rem]" aria-hidden="true">
              <BlobArrowIcon />
            </span>
            <span class="relative z-10 w-full whitespace-nowrap pl-14 pr-6 text-center text-fs-ui font-bold uppercase tracking-widest text-mauve transition-all duration-500 ease-[cubic-bezier(0.65,0,0.076,1)] group-hover:text-white">Webinary i medytacje</span>
          </a>
        </div>
      </div>
    </div>
  </section>
</div>
          <div class="blob-bg absolute left-1/2 top-4 -z-10 -ml-[5.65rem] h-[11.3rem] w-[11.3rem] bg-white shadow-sm transition-all duration-500 ease-out origin-center group-hover:!inset-0 group-hover:!ml-0 group-hover:!h-full group-hover:!w-full group-hover:!rounded-[30px] group-hover:!bg-white/95 group-hover:!shadow-2xl group-hover:!shadow-mauve/10" style="border-radius: 54% 46% 42% 58% / 44% 48% 52% 56%;"></div>

---
import { getOptimizedImageVariants } from '../lib/optimizedImages.js';

const {
  src,
  alt,
  class: className = '',
  style,
  loading = 'lazy',
  decoding = 'async',
  fetchpriority,
  sizes = '100vw',
  width,
  height,
} = Astro.props;

const variants = getOptimizedImageVariants(src);
---

{variants ? (
  <picture>
    <source type="image/webp" srcset={variants.srcSet} sizes={sizes} />
    <img src={src} alt={alt} class={className} style={style} loading={loading} decoding={decoding} fetchpriority={fetchpriority} width={width} height={height} />
  </picture>
) : (
  <img src={src} alt={alt} class={className} style={style} loading={loading} decoding={decoding} fetchpriority={fetchpriority} width={width} height={height} />
)}